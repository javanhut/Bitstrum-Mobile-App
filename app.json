{
  "expo": {
    "name": "Bitstrum",
    "slug": "bitstrum-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bitstrum",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.bitstrum.mobile",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#06101c"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "platforms": ["android"],
    "plugins": [
      "expo-router"
    ]
  }
}
