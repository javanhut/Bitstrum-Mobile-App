{
  "expo": {
    "name": "Bitstrum",
    "slug": "bitstrum-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bitstrum",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/bitstrum_logo.png",
    "android": {
      "package": "com.bitstrum.mobile",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/bitstrum_logo.png",
        "backgroundColor": "#06101c"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "platforms": ["android"],
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
